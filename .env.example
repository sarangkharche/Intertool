# NextAuth v5
AUTH_SECRET=        # Generate with: openssl rand -base64 32
AUTH_TRUST_HOST=true

# GitHub OAuth (create at https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/callback/github  (or your production URL)
# Scopes: read:user, user:email
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth (optional — create at console.cloud.google.com/apis/credentials)
# Callback URL: http://localhost:3000/api/auth/callback/google  (or your production URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_ALLOWED_DOMAINS=acme.com  # Optional: comma-separated, also configurable via /admin UI

# ── Self-hosted mode (default) ──
# Option A: Configure S3 via /admin UI (local dev, Docker — writable filesystem)
# Option B: Set env vars below (Vercel deployment — read-only filesystem)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=              # Optional: custom endpoint for MinIO, R2, Wasabi
# INTERTOOL_ADMIN=username  # Optional: GitHub username of admin user
# GITHUB_ORG=               # Optional: restrict sign-in to members of this GitHub org
# INTERTOOL_API_KEY=        # Optional: API key for CLI publishing (generate: openssl rand -hex 32)

# ── SaaS mode (intertool.sh) ──
# Uncomment to enable multi-tenant org-based routing.
# Each org gets a subdomain: {org}.intertool.sh
# INTERTOOL_MODE=saas
# INTERTOOL_DOMAIN=intertool.sh
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
